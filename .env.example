# Server
PORT=5010

# ── Claude Authentication ──────────────────────────
# Multi-account tokens (comma-separated)
CLAUDE_OAUTH_TOKENS=
CLAUDE_OAUTH_REFRESH_TOKENS=

# Multi-account credentials files (comma-separated paths)
CLAUDE_CREDENTIALS_FILES=

# Single account
CLAUDE_OAUTH_TOKEN=
CLAUDE_OAUTH_REFRESH_TOKEN=

# File/Keychain fallback
CLAUDE_CREDENTIALS_FILE=~/.claude/.credentials.json
CLAUDE_KEYCHAIN_SERVICE=Claude Code-credentials

# Failover
CLAUDE_MAX_FAILURES=3
CLAUDE_COOLDOWN_SECONDS=120

# ── Codex Authentication ───────────────────────────
# Multi-account (comma-separated)
CODEX_AUTH_FILES=

# Single account
CODEX_AUTH_FILE=~/.codex/auth.json

# Failover
CODEX_MAX_FAILURES=3
CODEX_COOLDOWN_SECONDS=120

# ── Advanced ───────────────────────────────────────
CLAUDE_API_URL=https://api.anthropic.com/v1/messages
CLAUDE_CODE_VERSION=2.1.76
CLAUDE_OAUTH_TOKEN_URL=https://console.anthropic.com/api/oauth/token
CLAUDE_OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
CODEX_API_URL=https://chatgpt.com/backend-api/codex/responses
CODEX_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
CODEX_TOKEN_URL=https://auth.openai.com/oauth/token
