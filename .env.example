# 기본값은 코드에 내장되어 있어 별도 설정 불필요.
# 멀티 계정이나 기본값 변경이 필요한 경우에만 설정하세요.
# 전체 환경변수 목록은 README를 참조하세요.

# ── 멀티 계정 (필요시에만) ────────────────────────
# CLAUDE_OAUTH_TOKENS=sk-ant-oat01-aaa...,sk-ant-oat01-bbb...
# CLAUDE_CREDENTIALS_FILES=~/.claude/.credentials.json,~/.claude/.credentials2.json
# CODEX_AUTH_FILES=~/.codex/auth1.json,~/.codex/auth2.json

# ── Docker 사용 시 (필수) ─────────────────────────
# CLAUDE_CREDENTIALS_FILE=/app/claude_credentials.json
# CODEX_AUTH_FILE=/app/codex_credentials.json
